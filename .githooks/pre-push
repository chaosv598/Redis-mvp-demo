#!/usr/bin/env bash
# pre-push hook —— push 前本地跑 3 个 quick check(避免明显错误污染 CI)
#
# 检查:
#   1. check-series(series vs patches/ 一致,~1s)
#   2. check-deps(metadata 的 applies_on_top 与 series 一致,~1s)
#   3. doctor(7 铁律自检,~2s)
#
# 不跑 check-apply(网络依赖 + 慢),留给 CI 跑
#
# 跳过本钩子: git push --no-verify
# 禁用本钩子: chmod -x .githooks/pre-push(在仓库 settings)
# 安装: bash tools/install-hooks.sh
set -e

# 只在 boostkit 仓激活
[ -f boostkit.yaml ] || exit 0
grep -q "kind: PatchOverlay" boostkit.yaml || exit 0

echo "[pre-push] boostkit pre-push hook ..."
ROOT="$(git rev-parse --show-toplevel)"

FAIL=0

# 1) check-series
echo "[pre-push] 1/3 check-series ..."
if (cd "$ROOT" && python3 tools/check-series.py); then
    echo "[pre-push] ✓ check-series"
else
    echo "[pre-push] ✗ check-series 失败"
    FAIL=1
fi

# 2) check-deps
echo "[pre-push] 2/3 check-deps ..."
if (cd "$ROOT" && python3 tools/check-deps.py); then
    echo "[pre-push] ✓ check-deps"
else
    echo "[pre-push] ✗ check-deps 失败"
    FAIL=1
fi

# 3) doctor
echo "[pre-push] 3/3 doctor ..."
if (cd "$ROOT" && python3 tools/doctor.py); then
    echo "[pre-push] ✓ doctor"
else
    echo "[pre-push] ✗ doctor 失败"
    FAIL=1
fi

if [ "$FAIL" = "1" ]; then
    echo
    echo "[pre-push] ✗ 至少一个 check 失败,终止 push"
    echo "  跳过本钩子: git push --no-verify(不推荐)"
    exit 1
fi

echo "[pre-push] ✓ 全部通过,继续 push"
exit 0
