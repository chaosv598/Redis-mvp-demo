#!/usr/bin/env bash
# pre-push hook —— push 前跑 verify.sh
#
# 跳过: git push --no-verify
# 禁用: chmod -x .githooks/pre-push
# 启用: bash tools/install-hooks.sh
set -e

# 只在 boostkit 风格仓激活(通过 series 文件判断)
[ -d versions ] || exit 0
ls versions/*/series >/dev/null 2>&1 || exit 0

echo "[pre-push] running verify.sh ..."
ROOT="$(git rev-parse --show-toplevel)"

if bash "$ROOT/tools/verify.sh"; then
    echo "[pre-push] ✓ verify 通过,继续 push"
    exit 0
else
    echo
    echo "[pre-push] ✗ verify 失败,终止 push"
    echo "  跳过本钩子: git push --no-verify(不推荐)"
    exit 1
fi
